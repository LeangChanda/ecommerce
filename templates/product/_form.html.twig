{{ form_start(form) }}

<div class="row">

    <div class="col-md-6 mb-3">
        {{ form_label(form.name) }}
        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="col-md-6 mb-3">
        {{ form_label(form.slug) }}
        {{ form_widget(form.slug, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.slug) }}
    </div>

    <div class="col-12 mb-3">
        {{ form_label(form.shortDescription) }}
        {{ form_widget(form.shortDescription, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="col-12 mb-3">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {
            'attr': {
                'class': 'form-control',
                'rows': 5
            }
        }) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_label(form.price) }}
        {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.price) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_label(form.stock) }}
        {{ form_widget(form.stock, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.stock) }}
    </div>

    <div class="col-md-4 mb-3">
        {{ form_label(form.image) }}
        {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
    </div>

    <div class="col-md-6 mb-3">
        {{ form_label(form.category) }}
        {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
    </div>

    <div class="col-md-3 mb-3 d-flex align-items-center">
        <div class="form-check mt-4">
            {{ form_widget(form.isFeatured, {'attr': {'class': 'form-check-input'}}) }}
            {{ form_label(form.isFeatured, null, {'label_attr': {'class': 'form-check-label'}}) }}
        </div>
    </div>

    <div class="col-md-3 mb-3 d-flex align-items-center">
        <div class="form-check mt-4">
            {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
            {{ form_label(form.isActive, null, {'label_attr': {'class': 'form-check-label'}}) }}
        </div>
    </div>
</div>

<div class="text-end mt-4">
    <button class="btn btn-success px-4">
        {{ button_label|default('Save') }}
    </button>
</div>

{{ form_end(form) }}