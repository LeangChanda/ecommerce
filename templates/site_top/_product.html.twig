<section class="py-5 bg-light">

    <div class="container">

        <h2 class="mb-4">
            Featured Products
        </h2>

        <div class="row">

            {% for i in 1..8 %}

                <div class="col-lg-3 col-md-4 mb-4">

                    <div class="card">

                        <img
                            src="https://via.placeholder.com/250x220"
                            class="card-img-top"
                            alt="Product"
                        >

                        <div class="card-body">

                            <h5>
                                Product {{ i }}
                            </h5>

                            <strong>
                                $9.99
                            </strong>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    </div>

</section>